generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  notelp    String? // Nomor telepon (opsional)
  address   String? // Alamat (opsional) 
  bio       String? // Bio (opsional)
  avatar    String? // URL foto profil (opsional)
  role      Role     @default(user) // Role: user, admin, instruktur
  lastSeen  DateTime @default(now()) // Last active timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Instruktur profile
  bidangKeahlian String? // Bidang keahlian (hanya untuk instruktur)
  pengalaman     String? // Pengalaman (hanya untuk instruktur)

  // Dashboard progress fields
  class        Grade @default(X)
  points       Int   @default(0) // Total points
  badges       Int   @default(0) // Total badges
  level        Int   @default(1) // User level
  quizzes      Int   @default(0) // Total quizzes completed
  streak       Int   @default(0) // Current streak (days)
  averageScore Int   @default(0) // Average quiz score

  // Relations
  newsArticles                                      News[]               @relation("authorNews")
  userConversations                                 ChatConversation[]   @relation("userConversations")
  instructorConversations                           ChatConversation[]   @relation("instructorConversations")
  sentMessages                                      ChatMessage[]        @relation("sentMessages")
  schedules                                         Schedule[]           @relation("instructorSchedules")
  material                                          Material[]
  courseEnrollments                                 CourseEnrollment[]
  competitions                                      Competition[]        @relation("competitionInstructor")
  friends1                                          Friendship[]         @relation("Friends1")
  friends2                                          Friendship[]         @relation("Friends2")
  forumMessages                                     ForumMessage[]       @relation("forumMessages")
  favoritedByUsers                                  FavoriteInstructor[] @relation("InstructorFavorites")
  favoritedInstructors                              FavoriteInstructor[] @relation("UserFavorites")
  materialinvite_materialinvite_instructorIdTousers MaterialInvite[]     @relation("materialinvite_instructorIdTousers")
  materialinvite_materialinvite_userIdTousers       MaterialInvite[]     @relation("materialinvite_userIdTousers")
  sentNotifications                                 Notification[]       @relation("senderNotifications")
  notifications                                     Notification[]       @relation("userNotifications")
  programs                                          Program[]            @relation("programInstructor")
  programEnrollments                                ProgramEnrollment[]
  quizAttempts                                      QuizAttempt[]
  createdQuizzes                                    MaterialQuiz[]       @relation("createdQuizzes")
  leaderboard                                       Leaderboard[]

  @@map("users")
}

model Leaderboard {
  id        String   @id @default(cuid())
  uid       String
  score     Int      @default(0)
  rank      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [uid], references: [id], onDelete: Cascade)

  @@index([uid])
  @@map("leaderboard")
}

model FavoriteInstructor {
  id           String   @id @default(cuid())
  userId       String
  instructorId String
  createdAt    DateTime @default(now())
  instructor   User     @relation("InstructorFavorites", fields: [instructorId], references: [id], onDelete: Cascade)
  user         User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instructorId])
  @@index([userId])
  @@index([instructorId])
  @@map("favorite_instructors")
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  deskripsi String   @db.Text
  content   String   @db.LongText
  image     String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("authorNews", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([authorId])
  @@map("news")
}

model ForumMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  senderId  String
  createdAt DateTime @default(now())
  sender    User     @relation("forumMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([createdAt])
  @@map("forum_messages")
}

model ChatConversation {
  id           String        @id @default(cuid())
  userId       String
  instructorId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  instructor   User          @relation("instructorConversations", fields: [instructorId], references: [id], onDelete: Cascade)
  user         User          @relation("userConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@unique([userId, instructorId])
  @@index([userId])
  @@index([instructorId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  content        String           @db.Text
  isRead         Boolean          @default(false)
  readAt         DateTime?
  attachmentUrl  String?
  attachmentType String?
  isEdited       Boolean          @default(false)
  editedAt       DateTime?
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("chat_messages")
}

model Schedule {
  id              String         @id @default(cuid())
  title           String
  description     String         @db.Text
  fullDescription String?        @db.LongText
  date            DateTime
  time            String
  location        String
  pemateri        String
  thumbnailUrl    String?
  status          ScheduleStatus @default(segera_hadir)
  instructorId    String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  instructor      User           @relation("instructorSchedules", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@index([date])
  @@index([status])
  @@map("schedules")
}

model Competition {
  id              String              @id @default(cuid())
  title           String
  description     String?             @db.Text
  date            DateTime
  prize           String
  category        CompetitionCategory
  thumbnailUrl    String?
  instructorId    String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  contactEmail    String?
  contactNumber   String?
  contactPerson   String?
  judgingCriteria Json?
  location        String?
  maxParticipants Int?
  prizes          Json?
  requirements    Json?
  schedules       Json?
  instructor      User                @relation("competitionInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@index([date])
  @@map("competitions")
}

model Notification {
  id           String             @id @default(cuid())
  userId       String
  type         NotificationType   @default(basic)
  status       NotificationStatus @default(unread)
  title        String
  message      String             @db.Text
  icon         String?
  resourceType String?
  resourceId   String?
  actionUrl    String?
  inviteToken  String?            @unique
  senderId     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sender       User?              @relation("senderNotifications", fields: [senderId], references: [id])
  user         User               @relation("userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([inviteToken])
  @@index([senderId], map: "Notification_senderId_fkey")
  @@map("notifications")
}

model Program {
  id           String               @id @default(cuid())
  title        String
  description  String?              @db.Text
  grade        MaterialGrade
  category     MaterialCategory
  thumbnailUrl String?
  instructorId String
  duration     String?
  syllabus     Json?
  requirements Json?
  benefits     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  instructor   User                 @relation("programInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  materials    Material[]           @relation("programMaterials")
  enrollments  ProgramEnrollment[]

  @@index([instructorId])
  @@map("programs")
}

model ProgramEnrollment {
  id         String   @id @default(cuid())
  programId  String
  userId     String
  enrolledAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([programId, userId])
  @@index([programId])
  @@index([userId])
  @@map("program_enrollments")
}

model Attendance {
  id                String   @id @default(cuid())
  userId            String
  materialId        String
  status            String   @default("hadir")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  clarity           String?
  date              String?
  endTime           String?
  feedback          String?  @db.Text
  instructorArrival String?
  location          String?
  notes             String?
  rating            Int?
  reason            String?
  relevance         String?
  session           String?
  startTime         String?
  time              String?

  @@unique([userId, materialId], map: "Attendance_userId_materialId_key")
  @@index([materialId], map: "Attendance_materialId_idx")
  @@index([userId], map: "Attendance_userId_idx")
  @@map("attendance")
}

model CourseEnrollment {
  id         String                @id @default(cuid())
  materialId String
  userId     String
  role       CourseEnrollment_Role
  enrolledAt DateTime              @default(now())
  material   Material              @relation(fields: [materialId], references: [id], onDelete: Cascade, map: "CourseEnrollment_materialId_fkey")
  users      User                  @relation(fields: [userId], references: [id], onDelete: Cascade, map: "CourseEnrollment_userId_fkey")

  @@unique([materialId, userId], map: "CourseEnrollment_materialId_userId_key")
  @@index([userId], map: "CourseEnrollment_userId_idx")
  @@map("course_enrollments")
}

model Material {
  id                                             String             @id @default(cuid())
  title                                          String
  description                                    String?
  grade                                          MaterialGrade
  thumbnailUrl                                   String?
  instructorId                                   String
  nextCourseId                                   String?
  createdAt                                      DateTime           @default(now())
  updatedAt                                      DateTime           @updatedAt
  date                                           DateTime           @default(now())
  category                                       MaterialCategory
  participants                                   String?
  startedAt                                      String?
  content                                        String?            @db.LongText
  link                                           String?
  materialType                                   String?
  parentId                                       String?
  programId                                      String?
  courseenrollment                               CourseEnrollment[]
  users                                          User               @relation(fields: [instructorId], references: [id], map: "Material_instructorId_fkey")
  material_material_nextCourseIdTomaterial       Material?          @relation("material_nextCourseIdTomaterial", fields: [nextCourseId], references: [id], map: "Material_nextCourseId_fkey")
  other_material_material_nextCourseIdTomaterial Material[]         @relation("material_nextCourseIdTomaterial")
  material_material_parentIdTomaterial           Material?          @relation("material_parentIdTomaterial", fields: [parentId], references: [id], map: "Material_parentId_fkey")
  other_material_material_parentIdTomaterial     Material[]         @relation("material_parentIdTomaterial")
  program                                        Program?           @relation("programMaterials", fields: [programId], references: [id], onDelete: SetNull, map: "Material_programId_fkey")
  materialinvite                                 MaterialInvite[]
  rekapan                                        Rekapan?
  quizzes                                        MaterialQuiz[]

  @@index([instructorId], map: "Material_instructorId_fkey")
  @@index([nextCourseId], map: "Material_nextCourseId_fkey")
  @@index([parentId], map: "Material_parentId_fkey")
  @@index([programId], map: "Material_programId_fkey")
  @@map("materials")
}

model MaterialInvite {
  id                                       String                @id @default(cuid())
  materialId                               String
  instructorId                             String
  token                                    String                @unique(map: "MaterialInvite_token_key")
  status                                   MaterialInvite_Status @default(pending)
  reason                                   String?               @db.Text
  createdAt                                DateTime              @default(now())
  updatedAt                                DateTime              @updatedAt
  userId                                   String
  users_materialinvite_instructorIdTousers User                  @relation("materialinvite_instructorIdTousers", fields: [instructorId], references: [id], map: "MaterialInvite_instructorId_fkey")
  material                                 Material              @relation(fields: [materialId], references: [id], onDelete: Cascade, map: "MaterialInvite_materialId_fkey")
  users_materialinvite_userIdTousers       User                  @relation("materialinvite_userIdTousers", fields: [userId], references: [id], onDelete: Cascade, map: "MaterialInvite_userId_fkey")

  @@index([instructorId], map: "MaterialInvite_instructorId_fkey")
  @@index([materialId], map: "MaterialInvite_materialId_idx")
  @@index([userId], map: "MaterialInvite_userId_idx")
  @@map("material_invites")
}

model Friendship {
  id             String        @id @default(cuid())
  requesterId    String
  addresseeId    String
  status         FriendshipStatus

  requester      User @relation("Friends1", fields: [requesterId], references: [id], map: "fk_friendship_requester")
  addressee      User @relation("Friends2", fields: [addresseeId], references: [id], map: "fk_friendship_addressee")

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}


// ─── Rekapan (Ringkasan Materi) ───────────────────────────────────

model Rekapan {
  id         String   @id @default(cuid())
  materialId String   @unique
  content    String   @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@map("rekapan")
}

// ─── Material Quiz System ─────────────────────────────────────────

model MaterialQuiz {
  id          String   @id @default(cuid())
  materialId  String?
  creatorId   String?
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  material  Material?       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  creator   User?           @relation("createdQuizzes", fields: [creatorId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([materialId])
  @@index([creatorId])
  @@map("material_quizzes")
}

model QuizQuestion {
  id       String @id @default(cuid())
  quizId   String
  question String @db.Text
  order    Int    @default(0)

  quiz    MaterialQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizOption {
  id         String  @id @default(cuid())
  questionId String
  text       String  @db.Text
  isCorrect  Boolean @default(false)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("quiz_options")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  totalScore  Int
  answers     Json
  completedAt DateTime @default(now())

  quiz MaterialQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

enum Grade {
  X
  XI
  XII
}

enum Role {
  user
  admin
  instruktur
}

enum ScheduleStatus {
  segera_hadir
  ongoing
  completed
}

enum CompetitionCategory {
  Tahfidz
  Seni
  Bahasa
  Lainnya
}

enum NotificationType {
  basic
  invitation
}

enum NotificationStatus {
  unread
  read
  accepted
  rejected
  expired
}

enum CourseEnrollment_Role {
  user
  instructor
  assistant
}

enum FriendshipStatus {
  Pending
  Friend
  Rejected
  Blocked
}

enum MaterialGrade {
  X
  XI
  XII
}

enum MaterialInvite_Status {
  pending
  accepted
  rejected
  expired
}

enum MaterialCategory {
  Wajib
  Extra
  NextLevel
  Susulan
}

enum QuizStatus {
  completed
  inProgress
  notStarted
}
