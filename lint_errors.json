</span>\r\n                        </>\r\n                      ) : (\r\n                        <>\r\n                          <LogIn className=\"w-5 h-5\" strokeWidth={3} />\r\n                          <span>Masuk Sekarang</span>\r\n                        </>\r\n                      )}\r\n                    </button>\r\n\r\n                    {/* Divider */}\r\n                    <div className=\"flex items-center gap-3 mt-1\">\r\n                      <div className=\"flex-1 h-[2px] bg-slate-200 rounded-full\"></div>\r\n                      <span className=\"text-xs font-bold text-slate-400 uppercase tracking-wider\">\r\n                        atau\r\n                      </span>\r\n                      <div className=\"flex-1 h-[2px] bg-slate-200 rounded-full\"></div>\r\n                    </div>\r\n\r\n                    {/* Google Button */}\r\n                    <button\r\n                      type=\"button\"\r\n                      disabled={isLoading || googleLoading}\r\n                      onClick={() => {\r\n                        setGoogleLoading(true);\r\n                        signIn(\"google\", { callbackUrl: \"/overview\" });\r\n                      }}\r\n                      className=\"w-full py-4 rounded-2xl bg-white text-slate-700 font-black text-base border-2 border-slate-200 border-b-4 hover:bg-slate-50 hover:border-slate-300 active:border-b-2 active:translate-y-0.5 transition-all disabled:opacity-70 disabled:cursor-not-allowed flex items-center justify-center gap-3 shadow-sm\"\r\n                    >\r\n                      {googleLoading ? (\r\n                        <Loader2\r\n                          className=\"w-5 h-5 animate-spin\"\r\n                          strokeWidth={3}\r\n                        />\r\n                      ) : (\r\n                        <svg className=\"w-5 h-5 shrink-0 shadow-sm\" viewBox=\"0 0 24 24\">\r\n                          <path\r\n                            fill=\"#4285F4\"\r\n                            d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z\"\r\n                          />\r\n                          <path\r\n                            fill=\"#34A853\"\r\n                            d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\"\r\n                          />\r\n                          <path\r\n                            fill=\"#FBBC05\"\r\n                            d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z\"\r\n                          />\r\n                          <path\r\n                            fill=\"#EA4335\"\r\n                            d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\"\r\n                          />\r\n                        </svg>\r\n                      )}\r\n                      <span>Masuk dengan Google</span>\r\n                    </button>\r\n                  </form>\r\n                </TabsContent>\r\n\r\n                {/* === FORM SIGN UP === */}\r\n                <TabsContent\r\n                  value=\"signup\"\r\n                  className=\"animate-in fade-in-50 zoom-in-95 duration-300 focus-visible:outline-none\"\r\n                >\r\n                  <form onSubmit={handleSignUp} className=\"space-y-5\">\r\n                    {error && (\r\n                      <div className=\"rounded-2xl bg-red-50 p-4 border-2 border-red-100 flex items-start gap-3\">\r\n                        <div className=\"w-1.5 h-1.5 rounded-full bg-red-500 mt-2 shrink-0\" />\r\n                        <p className=\"text-sm text-red-600 font-bold\">\r\n                          {error}\r\n                        </p>\r\n                      </div>\r\n                    )}\r\n\r\n                    <div className=\"space-y-2\">\r\n                      <label\r\n                        htmlFor=\"full-name\"\r\n                        className=\"text-slate-700 font-bold text-sm ml-1 block\"\r\n                      >\r\n                        Nama Lengkap\r\n                      </label>\r\n                      <input\r\n                        id=\"full-name\"\r\n                        name=\"full-name\"\r\n                        type=\"text\"\r\n                        placeholder=\"Nama Lengkap\"\r\n                        required\r\n                        className=\"w-full py-4 px-5 rounded-2xl border-2 border-slate-200 bg-slate-50 focus:bg-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_4px_0_0_#10b981] transition-all font-bold text-slate-700 placeholder:font-medium placeholder:text-slate-400\"\r\n                      />\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                      <label\r\n                        htmlFor=\"signup-email\"\r\n                        className=\"text-slate-700 font-bold text-sm ml-1 block\"\r\n                      >\r\n                        Email\r\n                      </label>\r\n                      <input\r\n                        id=\"signup-email\"\r\n                        name=\"signup-email\"\r\n                        type=\"email\"\r\n                        placeholder=\"nama@email.com\"\r\n                        required\r\n                        className=\"w-full py-4 px-5 rounded-2xl border-2 border-slate-200 bg-slate-50 focus:bg-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_4px_0_0_#10b981] transition-all font-bold text-slate-700 placeholder:font-medium placeholder:text-slate-400\"\r\n                      />\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                      <label\r\n                 